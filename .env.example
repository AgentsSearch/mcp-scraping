# MCP Agent Search Engine — Environment Variables
# Copy to .env and fill in the values you need.

# --- Required for LLM analysis ---
OPENAI_API_KEY=

# --- Smithery (probing Smithery-hosted servers) ---
SMITHERY_API_KEY=

# --- API Keys (Group 1: static key injection) ---
APIFY_API_TOKEN=
KLAVIS_API_KEY=
CARSXE_API_KEY=
PACKMIND_API_KEY=
COTRADER_API_KEY=
GURU_API_KEY=

# --- Vendor OAuth (Group 5: requires app registration with vendor) ---
ATLASSIAN_CLIENT_ID=
ATLASSIAN_CLIENT_SECRET=
MONDAY_CLIENT_ID=
MONDAY_CLIENT_SECRET=
WEBFLOW_CLIENT_ID=
WEBFLOW_CLIENT_SECRET=
TRAYD_CLIENT_ID=
TRAYD_CLIENT_SECRET=
